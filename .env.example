# MySQL Configuration Environment Variables
# Copy this file to .env and update the values as needed

# Database Host (use 'localhost' for local, 'mysql' for Docker network, or the server IP)
MYSQL_HOST=localhost

# Database Port (default is 3306)
MYSQL_PORT=3306

# Database Credentials
MYSQL_USER=your_username
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=your_database

# Character Set and Collation (optional defaults provided)
MYSQL_CHARSET=utf8mb4
MYSQL_COLLATION=utf8mb4_unicode_ci

# MySQL SQL Mode (optional default provided)
MYSQL_SQL_MODE=TRADITIONAL
